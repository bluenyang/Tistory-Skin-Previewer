---
const {
  class: bodyClass="",
} = Astro.props;

const isPreview = import.meta.env.DEV;
---

<body id="[##_body_id_##]" class={bodyClass}>
  <s_t3>
    <slot />
  </s_t3>
  
  {isPreview ? 
    <script src="/src/scripts/common.ts"></script> : 
    <script is:inline src="./images/common.js"></script>
  }
</body>